{
  "name": "gemini-doc-desktop",
  "private": true,
  "version": "0.1.0",
  "main": "main.cjs",
  "scripts": {
    "dev:renderer": "npm --prefix ../web run dev -- --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "npm --prefix ../web run build -- --base ./ --outDir ../desktop/renderer-dist",
    "start": "npm run build:renderer && electron .",
    "pack:dir": "npm run build:renderer && electron-builder --dir",
    "pack:win": "npm run build:renderer && electron-builder --win nsis"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ycdoc.desktop",
    "productName": "YC-Doc",
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer-dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
